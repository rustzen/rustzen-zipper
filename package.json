{
  "name": "@rustzen/zipper",
  "version": "0.2.0",
  "description": "Rust-based CLI & JS library for zipping dist folders",
  "main": "index.js",
  "bin": {
    "rz-zip": "index.js"
  },
  "files": [
    "index.js",
    "README.md",
    "scripts/install.js",
    "scripts/verify-package.js"
  ],
  "scripts": {
    "install": "node scripts/install.js",
    "test": "cargo test --locked",
    "build": "cargo build",
    "postbuild": "node scripts/test.js -f=%Y%m%d%H%M%S",
    "verify:package": "node scripts/verify-package.js",
    "ci": "cargo build --locked && cargo test --locked && cargo clippy --locked -- -D warnings && node scripts/verify-package.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rustzen/rustzen-zipper.git"
  },
  "keywords": [
    "zip",
    "rust",
    "cli",
    "dist",
    "postbuild"
  ],
  "author": "Rustzen Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rustzen/rustzen-zipper/issues"
  },
  "homepage": "https://github.com/rustzen/rustzen-zipper#readme"
}
